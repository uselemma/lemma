{
  "theme": "almond",
  "name": "Lemma",
  "styling": {
    "css": "/style.css"
  },
  "colors": {
    "primary": "#755CFE",
    "light": "#755CFE",
    "dark": "#1D1956"
  },
  "fonts": {
    "heading": {
      "family": "Britti Sans",
      "weight": 500,
      "format": "woff2",
      "source": "/fonts/britti-sans-medium.woff2"
    },
    "body": {
      "family": "Britti Sans",
      "weight": 400,
      "format": "woff2",
      "source": "/fonts/britti-sans-regular.woff2"
    }
  },
  "icons": {
    "library": "lucide"
  },
  "logo": {
    "light": "/logo-light.svg",
    "dark": "/logo-dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Talk to us",
        "href": "https://cal.com/jerryzhang/lemma-demo"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://platform.uselemma.ai"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "icon": "rocket",
            "expanded": true,
            "pages": [
              "getting-started/introduction",
              "getting-started/quickstart",
              "getting-started/concepts"
            ]
          },
          {
            "group": "Instrumentation",
            "icon": "workflow",
            "expanded": true,
            "pages": [
              "tracing/overview",
              "tracing/instrumentation/instrument-an-agent",
              "tracing/instrumentation/setup",
              "tracing/instrumentation/traces",
              "tracing/instrumentation/generations",
              "tracing/instrumentation/tool-calls",
              "tracing/instrumentation/spans",
              "tracing/instrumentation/context",
              {
                "group": "Troubleshooting",
                "expanded": false,
                "pages": [
                  "tracing/troubleshooting/debug-mode",
                  "tracing/troubleshooting/common-issues"
                ]
              },
              {
                "group": "Reference",
                "expanded": false,
                "pages": [
                  "reference/trace-contract",
                  "reference/good-vs-bad-traces"
                ]
              }
            ]
          },
          {
            "group": "Integrations",
            "icon": "plug-zap",
            "expanded": true,
            "pages": [
              "integrations/openai-agents",
              "integrations/vercel-ai",
              "integrations/langchain",
              "integrations/langgraph"
            ]
          },
          {
            "group": "Connections",
            "icon": "plug",
            "expanded": true,
            "pages": [
              "connections/mcp",
              "connections/webhooks"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "https://api.uselemma.ai/openapi.json"
      }
    ]
  },
  "redirects": [
    {
      "source": "/getting-started/minimum-viable-trace",
